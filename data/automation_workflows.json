[
  {
    "name": "Backend · Tech + Market",
    "trigger": "manual",
    "steps": [
      {
        "type": "refresh_tech_watch",
        "params": {
          "timeout": 120
        }
      },
      {
        "type": "refresh_market",
        "params": {
          "symbols": "^FCHI,BNP.PA,AIR.PA,MC.PA,OR.PA,ORA.PA",
          "interval": "1d",
          "period": "6mo",
          "timeout": 30
        }
      }
    ]
  },
  {
    "name": "Tech Radar (n8n)",
    "trigger": "manual",
    "steps": [
      {
        "type": "n8n_webhook",
        "params": {
          "url": "http://127.0.0.1:5678/webhook/tech-radar",
          "timeout": 120,
          "payload": {
            "scope": "tech_only",
            "timeout": 90
          }
        }
      }
    ]
  },
  {
    "name": "Market Radar (n8n)",
    "trigger": "manual",
    "steps": [
      {
        "type": "n8n_webhook",
        "params": {
          "url": "http://127.0.0.1:5678/webhook/market-radar",
          "timeout": 120,
          "payload": {
            "symbols": "^FCHI,BNP.PA,AIR.PA,MC.PA,OR.PA,ORA.PA",
            "interval": "1d",
            "period": "6mo"
          }
        }
      }
    ]
  },
  {
    "name": "Daily Full · Tech + Market (via n8n)",
    "trigger": "manual",
    "steps": [
      {
        "type": "n8n_webhook",
        "params": {
          "url": "http://127.0.0.1:5678/webhook/daily-full",
          "timeout": 120,
          "payload": {}
        }
      }
    ]
  }
]