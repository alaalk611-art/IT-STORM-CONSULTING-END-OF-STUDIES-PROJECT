# =========================
# URLs (Docker network)
# =========================
BACKEND_API_BASE_URL=http://backend:8001
MARKET_API_BASE_URL=http://backend:8001
API_BASE_URL=http://backend:8001

# =========================
# Ollama (Docker service)
# =========================
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_URL=http://ollama:11434
LOCAL_LLM_BASEURL=http://ollama:11434
OLLAMA_DEFAULT_MODEL=llama3.2:3b

# =========================
# RAG / Chroma paths (Docker)
# =========================
VECTOR_COLLECTION=consulting
DEFAULT_COLLECTION=consulting

CHROMA_DB_DIR=/app/vectors
VECTOR_DB_PATH=/app/vectors

# IMPORTANT: dans rag_brain.py le default de RAG_DATA_DIR pointe sur un chemin Windows.
# En Docker, force /app/data pour éviter toute surprise.
RAG_DATA_DIR=/app/data

# =========================
# Embeddings (SentenceTransformers via HF cache)
# =========================
# Mettre "sentence-transformers" ici évite la branche FastEmbed.
EMBED_BACKEND=sentence-transformers
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# CrossEncoder = peut déclencher des downloads HF -> on coupe en Docker
ENABLE_CROSS_ENCODER=0
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Cache HF persistant (compatible avec volume hf_cache:/app/.cache)
HF_HOME=/app/.cache/huggingface
SENTENCE_TRANSFORMERS_HOME=/app/.cache/sentence_transformers
# TRANSFORMERS_CACHE est déprécié mais inoffensif si présent
TRANSFORMERS_CACHE=/app/.cache/huggingface
# =========================
# n8n
# =========================
N8N_BASE=http://host.docker.internal:5678

# =========================
# Perf / logs (optionnel)
# =========================
TOKENIZERS_PARALLELISM=false
LOG_LEVEL=INFO
RAG_DEBUG=false

# =========================
# Streamlit
# =========================
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_PORT=8501
