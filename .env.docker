# ============================
# Palier 1 : UI + API seulement
# ============================

# UI -> API (Docker network)
BACKEND_API_BASE_URL=http://backend:8001
MARKET_API_BASE_URL=http://backend:8001

# n8n pas lancé au palier 1 (on évite DNS error "n8n")
N8N_BASE_URL=http://localhost:5678

# ----------------------------
# Paths (Linux container)
# ----------------------------
RAG_DATA_DIR=/app/data
VECTOR_DB_PATH=/app/vectors
CHROMA_DB_DIR=/app/vectors

# ----------------------------
# Embeddings (si utilisé)
# ----------------------------
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBED_BACKEND=fastembed

# ----------------------------
# MLflow (pas lancé au palier 1, ok à garder)
# ----------------------------
MLFLOW_STORE=sqlite:////app/mlruns.db

# ----------------------------
# Ollama (pas lancé au palier 1)
# ----------------------------
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_URL=http://host.docker.internal:11434
LOCAL_LLM_BASEURL=http://host.docker.internal:11434
